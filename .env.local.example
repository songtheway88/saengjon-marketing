# ── 구글 시트 저장 ──────────────────────────────────────────────
# 설정 방법:
#   1. sheets.google.com → 새 스프레드시트 생성
#   2. 확장 프로그램 → Apps Script → lib/google-sheets.ts 주석 안의 코드 붙여넣기
#   3. 배포 → 새 배포 → 웹 앱 (실행: 나 / 액세스: 모든 사용자)
#   4. 배포 URL 복사 → 아래에 입력
GOOGLE_SHEETS_WEBHOOK_URL=

# ── Solapi 알림톡 (@생존마케팅 채널 → 고객 모바일) ──────────────
# 설정 방법:
#   1. console.solapi.com 가입
#   2. 개발 → API Key 관리 → API Key/Secret 복사
#   3. 카카오 → 채널 관리 → @생존마케팅 채널 연동 → pfId 복사
#   4. 카카오 → 알림톡 템플릿 → 템플릿 등록 → 심사 후 templateId 복사
#
# ※ 미설정 시 DEV 모드 (콘솔 로그만 출력, 실제 발송 안됨)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_PFID=                          # KA01PF... (채널 연동 후 발급)
SOLAPI_TEMPLATE_ID_WELCOME=           # KA01TP... (템플릿 심사 후 발급)
SOLAPI_TEMPLATE_ID_BROADCAST=         # 일괄 발송용 (나중에 추가)

# ── 관리자 페이지 ───────────────────────────────────────────────
ADMIN_PASSWORD=

# ── Supabase (선택 — 미설정 시 구글 시트만 사용) ────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
